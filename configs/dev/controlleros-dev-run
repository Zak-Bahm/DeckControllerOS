#!/bin/sh

set -eu

BASE_URL=""
ENDPOINT="/logs"
TIMEOUT_SECONDS=""
COMMAND=""
SHELL_SCRIPT=""

usage() {
	echo "Usage: $0 --base-url <http://host:port> [--endpoint </path>] [--timeout-seconds <n>] [--shell-script <name>] [<shell-command>]"
	echo "Example:"
	echo "  $0 --base-url http://192.168.1.10:8000 \"controlleros-dev-debug all\""
	echo "  $0 --base-url http://192.168.1.10:8000 --timeout-seconds 10 \"controlleros-dev-debug hidd-run\""
	echo "  $0 --base-url http://192.168.1.10:8000 --timeout-seconds 20 --shell-script test_step0_axes.sh"
}

extract_base_url_host() {
	echo "$1" | awk '
		{
			s = $0
			sub(/^[a-zA-Z]+:\/\//, "", s)
			sub(/\/.*/, "", s)
			sub(/:[0-9]+$/, "", s)
			print s
		}
	'
}

while [ "$#" -gt 0 ]; do
	case "$1" in
		--base-url)
			[ "$#" -ge 2 ] || {
				echo "error: $1 requires a value" >&2
				usage >&2
				exit 1
			}
			BASE_URL="$2"
			shift 2
			;;
		--endpoint)
			[ "$#" -ge 2 ] || {
				echo "error: --endpoint requires a value" >&2
				usage >&2
				exit 1
			}
			ENDPOINT="$2"
			shift 2
			;;
		--timeout-seconds)
			[ "$#" -ge 2 ] || {
				echo "error: --timeout-seconds requires a value" >&2
				usage >&2
				exit 1
			}
			TIMEOUT_SECONDS="$2"
			shift 2
			;;
		--shell-script)
			[ "$#" -ge 2 ] || {
				echo "error: --shell-script requires a value" >&2
				usage >&2
				exit 1
			}
			SHELL_SCRIPT="$2"
			shift 2
			;;
		-h|--help)
			usage
			exit 0
			;;
		--)
			shift
			break
			;;
		-*)
			echo "error: unknown argument: $1" >&2
			usage >&2
			exit 1
			;;
		*)
			break
			;;
	esac
done

if [ -n "$SHELL_SCRIPT" ]; then
	# --shell-script provided; remaining positional args are passed to the script
	SCRIPT_ARGS="${*:-}"
elif [ "$#" -ge 1 ]; then
	COMMAND="$*"
else
	echo "error: either <shell-command> or --shell-script is required" >&2
	usage >&2
	exit 1
fi

[ -n "$BASE_URL" ] || {
	echo "error: --base-url is required" >&2
	usage >&2
	exit 1
}

case "$BASE_URL" in
	*/ ) BASE_URL="${BASE_URL%/}" ;;
esac

case "$ENDPOINT" in
	/*) ;;
	*) ENDPOINT="/$ENDPOINT" ;;
esac

if [ -n "$TIMEOUT_SECONDS" ]; then
	case "$TIMEOUT_SECONDS" in
		''|*[!0-9]*)
			echo "error: --timeout-seconds must be a positive integer" >&2
			exit 1
			;;
	esac
	if [ "$TIMEOUT_SECONDS" -eq 0 ]; then
		echo "error: --timeout-seconds must be > 0" >&2
		exit 1
	fi
fi

# Bootstrap networking if needed.
BASE_HOST="$(extract_base_url_host "$BASE_URL")"
if command -v controlleros-dev-debug >/dev/null 2>&1; then
	controlleros-dev-debug net-setup "$BASE_HOST" || true
fi

# Download and prepare shell script if requested.
if [ -n "$SHELL_SCRIPT" ]; then
	TMP_SCRIPT="$(mktemp /tmp/controlleros-dev-run.script.XXXXXX)"
	SCRIPT_URL="$BASE_URL/$SHELL_SCRIPT"
	echo "Downloading script: $SCRIPT_URL"
	if command -v wget >/dev/null 2>&1; then
		wget -qO "$TMP_SCRIPT" "$SCRIPT_URL"
	elif command -v curl >/dev/null 2>&1; then
		curl -fsSo "$TMP_SCRIPT" "$SCRIPT_URL"
	else
		echo "error: need wget or curl to download script" >&2
		exit 1
	fi
	chmod +x "$TMP_SCRIPT"
	COMMAND="sh $TMP_SCRIPT ${SCRIPT_ARGS:-}"
	# Clean up the downloaded script on exit (append to existing trap later)
fi

POST_URL="$BASE_URL$ENDPOINT"
HOSTNAME="$(hostname 2>/dev/null || echo deck)"
TIMESTAMP_UTC="$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo unknown)"
TMP_OUT="$(mktemp /tmp/controlleros-dev-run.out.XXXXXX)"
TMP_PAYLOAD="$(mktemp /tmp/controlleros-dev-run.payload.XXXXXX)"
TMP_TIMEOUT_FLAG="$(mktemp /tmp/controlleros-dev-run.timeout.XXXXXX)"
trap 'rm -f "$TMP_OUT" "$TMP_PAYLOAD" "$TMP_TIMEOUT_FLAG" "${TMP_SCRIPT:-}"' EXIT INT TERM

list_child_pids() {
	parent_pid="$1"
	for status_file in /proc/[0-9]*/status; do
		[ -r "$status_file" ] || continue
		pid="${status_file#/proc/}"
		pid="${pid%/status}"
		ppid="$(sed -n 's/^PPid:[[:space:]]*//p' "$status_file" 2>/dev/null | head -n1)"
		[ -n "$ppid" ] || continue
		if [ "$ppid" = "$parent_pid" ]; then
			echo "$pid"
		fi
	done
}

kill_descendants() {
	parent_pid="$1"
	signal_name="$2"
	for child_pid in $(list_child_pids "$parent_pid"); do
		kill_descendants "$child_pid" "$signal_name"
		kill "-$signal_name" "$child_pid" 2>/dev/null || true
	done
}

TIMED_OUT=0
set +e
if [ -n "$TIMEOUT_SECONDS" ]; then
	if command -v setsid >/dev/null 2>&1; then
		setsid sh -c "$COMMAND" >"$TMP_OUT" 2>&1 &
		CMD_PID="$!"
	elif command -v busybox >/dev/null 2>&1 && busybox setsid true >/dev/null 2>&1; then
		busybox setsid sh -c "$COMMAND" >"$TMP_OUT" 2>&1 &
		CMD_PID="$!"
	else
		sh -c "$COMMAND" >"$TMP_OUT" 2>&1 &
		CMD_PID="$!"
	fi
	(
		sleep "$TIMEOUT_SECONDS"
		if kill -0 "$CMD_PID" 2>/dev/null; then
			: >"$TMP_TIMEOUT_FLAG"
			kill_descendants "$CMD_PID" TERM
			kill -TERM "$CMD_PID" 2>/dev/null || true
			sleep 1
			kill_descendants "$CMD_PID" KILL
			kill -KILL "$CMD_PID" 2>/dev/null || true
		fi
	) &
	WATCHDOG_PID="$!"

	wait "$CMD_PID"
	CMD_EXIT="$?"
	kill "$WATCHDOG_PID" 2>/dev/null || true
	wait "$WATCHDOG_PID" 2>/dev/null || true

		if [ -e "$TMP_TIMEOUT_FLAG" ]; then
			TIMED_OUT=1
			CMD_EXIT=124
		fi
else
	sh -c "$COMMAND" >"$TMP_OUT" 2>&1
	CMD_EXIT="$?"
fi
set -e

{
	printf 'timestamp_utc=%s\n' "$TIMESTAMP_UTC"
	printf 'deck_host=%s\n' "$HOSTNAME"
	printf 'command_timed_out=%s\n' "$TIMED_OUT"
	printf 'command_exit_code=%s\n' "$CMD_EXIT"
	printf 'command=%s\n' "$COMMAND"
	if [ -n "$TIMEOUT_SECONDS" ]; then
		printf 'timeout_seconds=%s\n' "$TIMEOUT_SECONDS"
	fi
	printf '\n'
	cat "$TMP_OUT"
} >"$TMP_PAYLOAD"

echo "Sending command output to: $POST_URL"

if command -v curl >/dev/null 2>&1; then
	curl -fsS -X POST \
		-H "Content-Type: text/plain" \
		-H "X-Deck-Host: $HOSTNAME" \
		-H "X-Command-Timed-Out: $TIMED_OUT" \
		-H "X-Command-Exit-Code: $CMD_EXIT" \
		-H "X-Command: $COMMAND" \
		--data-binary "@$TMP_PAYLOAD" \
		"$POST_URL" >/dev/null
elif command -v wget >/dev/null 2>&1; then
	if wget --help 2>&1 | grep -q -- '--post-file'; then
		wget -q -O /dev/null --post-file="$TMP_PAYLOAD" "$POST_URL"
	elif wget --help 2>&1 | grep -q -- '--method'; then
		wget -q -O /dev/null --method=POST --body-file="$TMP_PAYLOAD" "$POST_URL"
	else
		echo "error: available wget does not support POST upload" >&2
		exit 1
	fi
else
	echo "error: need curl or wget to upload logs" >&2
	exit 1
fi

echo "Command exit code: $CMD_EXIT"
if [ "$TIMED_OUT" -eq 1 ]; then
	echo "Command timed out after ${TIMEOUT_SECONDS}s"
fi
exit "$CMD_EXIT"
