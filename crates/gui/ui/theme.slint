// Design tokens for ControllerOS UI

export global Theme {
    // Font sizes
    out property <length> font-title: 56px;
    out property <length> font-heading: 40px;
    out property <length> font-body: 36px;
    out property <length> font-detail: 28px;
    out property <length> font-default: 28px;

    // Colors — Steam Big Picture palette
    out property <color> bg: #030203;
    out property <color> bg-devices: #0e141b;
    out property <color> bg-device-connected: #3d4450;
    out property <color> bg-dialog: #0e141b;
    out property <color> bg-overlay: #000000cc;
    out property <color> bg-button: #2f3338;
    out property <color> bg-button-pressed: #3c3f45;
    out property <color> separator: #23272d;
    out property <color> text-primary: white;
    out property <color> text-secondary: #8b929a;
    out property <color> text-muted: #8b929a;
    out property <color> status-connected: #44cc44;
    out property <color> status-disconnected: #cc4444;

    // Spacing
    out property <length> padding: 16px;
    out property <length> spacing: 16px;
    out property <length> spacing-sm: 12px;
    out property <length> spacing-lg: 24px;

    // Sizes
    out property <length> left-panel-width: 500px;
    out property <length> device-row-height: 96px;
    out property <length> status-bar-height: 64px;
    out property <length> button-height: 64px;
    out property <length> button-radius: 4px;
    out property <length> icon-button-size: 64px;
    out property <length> icon-size: 32px;
    out property <length> dialog-width: 600px;
    out property <length> dialog-height: 280px;
    out property <length> spinner-size: 24px;
    out property <length> separator-height: 1px;
    out property <length> border-radius-lg: 8px;
}

export component IconButton inherits Rectangle {
    in property <image> icon;
    callback clicked;

    width: Theme.icon-button-size;
    height: Theme.icon-button-size;
    border-radius: Theme.button-radius;
    background: ta.pressed ? Theme.bg-button-pressed : Theme.bg-button;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    Image {
        source: root.icon;
        width: Theme.icon-size;
        height: Theme.icon-size;
        horizontal-alignment: center;
        vertical-alignment: center;
        colorize: Theme.text-primary;
    }
}

export component SteamButton inherits Rectangle {
    in property <string> label;
    callback clicked;

    height: Theme.button-height;
    border-radius: Theme.button-radius;
    background: ta.pressed ? Theme.bg-button-pressed : Theme.bg-button;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: Theme.text-primary;
        font-size: Theme.font-default;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}
