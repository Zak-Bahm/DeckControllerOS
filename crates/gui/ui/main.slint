import { ListView, VerticalBox, HorizontalBox, Spinner } from "std-widgets.slint";
import { Theme, SteamButton, IconButton } from "theme.slint";

export struct BtDeviceModel {
    name: string,
    address: string,
    connected: bool,
    obj-path: string,
}

export component MainWindow inherits Window {
    title: "ControllerOS";
    preferred-width: 1280px;
    preferred-height: 800px;
    default-font-size: Theme.font-default;
    background: Theme.bg;

    in-out property <[BtDeviceModel]> devices: [];

    in-out property <bool> confirm-visible: false;
    in-out property <string> confirm-message: "";
    in-out property <string> pending-action: "";
    in-out property <int> pending-index: -1;

    in-out property <string> status-text: "";
    in-out property <bool> busy: false;

    callback disconnect(int);
    callback forget(int);
    callback restart-stack();
    callback restart();
    callback power-off();
    callback confirm-action();
    callback cancel-action();

    cancel-action => {
        confirm-visible = false;
        confirm-message = "";
        pending-action = "";
        pending-index = -1;
    }

    HorizontalLayout {
        spacing: Theme.spacing;

        // Left panel — fixed 1/3 width
        VerticalLayout {
            width: Theme.left-panel-width;
            padding: Theme.padding;
            spacing: Theme.spacing-sm;

            // Header
            Text {
                text: "ControllerOS";
                font-size: Theme.font-title;
                font-weight: 700;
                color: Theme.text-primary;
                horizontal-alignment: center;
            }

            // Status bar
            VerticalLayout {
                alignment: center;
                spacing: Theme.spacing-sm;

                if root.busy : Spinner {
                    indeterminate: true;
                    width: Theme.spinner-size;
                    height: Theme.spinner-size;
                }

                Text {
                    text: root.status-text;
                    color: Theme.text-muted;
                    font-size: Theme.font-detail;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }

            // Spacer pushes buttons to the bottom
            Rectangle {
                vertical-stretch: 1;
            }

            // System buttons
            VerticalLayout {
                spacing: Theme.spacing-sm;

                SteamButton {
                    label: "Reload";
                    clicked => {
                        root.confirm-message = "Reload System?";
                        root.pending-action = "restart-stack";
                        root.pending-index = -1;
                        root.confirm-visible = true;
                    }
                }

                SteamButton {
                    label: "Restart";
                    clicked => {
                        root.confirm-message = "Restart the system?";
                        root.pending-action = "restart";
                        root.pending-index = -1;
                        root.confirm-visible = true;
                    }
                }

                SteamButton {
                    label: "Power Off";
                    clicked => {
                        root.confirm-message = "Power off the system?";
                        root.pending-action = "power-off";
                        root.pending-index = -1;
                        root.confirm-visible = true;
                    }
                }
            }
        }

        // Right panel — fills remaining 2/3
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.bg-devices;
            clip: true;

            VerticalLayout {
                padding: Theme.padding;
                spacing: Theme.spacing-sm;

                Text {
                    text: "Bluetooth Devices";
                    font-size: Theme.font-heading;
                    font-weight: 700;
                    color: Theme.text-primary;
                    horizontal-alignment: left;
                }

                ListView {
                    vertical-stretch: 1;

                    for device[index] in root.devices : VerticalLayout {
                        height: Theme.device-row-height;

                        // Separator line above each row (except first)
                        if index > 0 : Rectangle {
                            height: Theme.separator-height;
                            background: Theme.separator;
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            background: device.connected ? Theme.bg-device-connected : transparent;

                            HorizontalLayout {
                                padding: Theme.padding;
                                alignment: stretch;

                                Text {
                                    text: device.name;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-body;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                HorizontalLayout {
                                    spacing: Theme.spacing-sm;
                                    alignment: end;

                                    if device.connected : IconButton {
                                        icon: @image-url("../assets/unlink.png");
                                        clicked => {
                                            root.disconnect(index);
                                        }
                                    }

                                    IconButton {
                                        icon: @image-url("../assets/delete.png");
                                        clicked => {
                                            root.confirm-message = "Forget " + device.name + "?";
                                            root.pending-action = "forget";
                                            root.pending-index = index;
                                            root.confirm-visible = true;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Confirmation dialog overlay
    if root.confirm-visible : Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.bg-overlay;

        Rectangle {
            width: Theme.dialog-width;
            height: Theme.dialog-height;
            background: Theme.bg-dialog;
            border-radius: Theme.border-radius-lg;

            VerticalBox {
                alignment: center;
                padding: Theme.spacing-lg;
                spacing: Theme.spacing;

                Text {
                    text: root.confirm-message;
                    color: Theme.text-primary;
                    font-size: Theme.font-heading;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                HorizontalBox {
                    alignment: center;
                    spacing: Theme.spacing-lg;

                    SteamButton {
                        label: "Confirm";
                        width: 200px;
                        clicked => {
                            root.confirm-action();
                        }
                    }

                    SteamButton {
                        label: "Cancel";
                        width: 200px;
                        clicked => {
                            root.cancel-action();
                        }
                    }
                }
            }
        }
    }
}
